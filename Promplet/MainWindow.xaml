<Window x:Class="Promplet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promplet"
        Width="500"
        Height="44"
        MinWidth="360"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False">
    <Border x:Name="PaletteRoot"
            Background="#F22B3038"
            BorderBrush="#805B6472"
            BorderThickness="1"
            CornerRadius="6"
            Padding="5">
        <DockPanel LastChildFill="True">
            <Button x:Name="CloseButton"
                    DockPanel.Dock="Right"
                    Content="X"
                    Width="28"
                    Height="28"
                    Margin="6,0,0,0"
                    Padding="0"
                    FontSize="12"
                    ToolTip="Exit Promplet"
                    Click="CloseButton_Click" />
            <Border x:Name="DragHandle"
                    DockPanel.Dock="Left"
                    Width="28"
                    Height="28"
                    Margin="0,0,6,0"
                    Background="#26313A"
                    BorderBrush="#47515F"
                    BorderThickness="1"
                    CornerRadius="4"
                    Cursor="SizeAll"
                    ToolTip="Drag palette">
                <TextBlock Text="::"
                           Foreground="#CBD5E1"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="Bold" />
            </Border>
            <Border DockPanel.Dock="Left"
                    Height="28"
                    Margin="0,0,6,0"
                    Padding="9,0"
                    Background="#1C2430"
                    BorderBrush="#3C4654"
                    BorderThickness="1"
                    CornerRadius="4">
                <TextBlock Text="AI Chat"
                           Foreground="#E5E7EB"
                           VerticalAlignment="Center"
                           FontSize="12"
                           FontWeight="SemiBold" />
            </Border>
            <ItemsControl x:Name="PromptButtons">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Button Content="{Binding Label}"
                                MinWidth="62"
                                Height="28"
                                Margin="2,0"
                                Padding="8,0"
                                FontSize="12"
                                Click="PromptButton_Click"
                                MouseRightButtonUp="PromptButton_RightClick" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </DockPanel>
    </Border>
</Window>
