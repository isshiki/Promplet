<Window x:Class="Promplet.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promplet Settings"
        Width="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource PrompletDialogBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{DynamicResource PrompletPromptButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style x:Key="WindowChromeButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletChromeForegroundBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrompletPromptButtonHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrompletPromptButtonPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="{DynamicResource PrompletDialogInputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="10,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="ToggleButton"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Root"
                                                Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="28" />
                                                </Grid.ColumnDefinitions>
                                                <ContentPresenter Grid.Column="0"
                                                                  Margin="10,0,4,0"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Center"
                                                                  RecognizesAccessKey="True" />
                                                <Path Grid.Column="1"
                                                      Width="8"
                                                      Height="5"
                                                      HorizontalAlignment="Center"
                                                      VerticalAlignment="Center"
                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                      Fill="{DynamicResource PrompletTextSecondaryBrush}" />
                                            </Grid>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonHoverBorderBrush}" />
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                                <ContentPresenter Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                                  TextElement.Foreground="{DynamicResource PrompletTextPrimaryBrush}"
                                                  VerticalAlignment="Center" />
                            </ToggleButton>
                            <Popup x:Name="PART_Popup"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   Placement="Bottom"
                                   PopupAnimation="Fade">
                                <Border Background="{DynamicResource PrompletDialogInputBackgroundBrush}"
                                        BorderBrush="{DynamicResource PrompletPromptButtonBorderBrush}"
                                        BorderThickness="1"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}">
                                    <ScrollViewer MaxHeight="180"
                                                  VerticalScrollBarVisibility="Auto">
                                        <ItemsPresenter />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
            <Setter Property="Background" Value="{DynamicResource PrompletDialogInputBackgroundBrush}" />
            <Setter Property="Padding" Value="10,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrompletPromptButtonHoverBackgroundBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource PrompletPromptButtonPressedBackgroundBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid Height="24">
                            <Track x:Name="PART_Track"
                                   VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Height="4"
                                                  Background="{DynamicResource PrompletAccentBrush}"
                                                  BorderThickness="0"
                                                  Command="Slider.DecreaseLarge" />
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Height="4"
                                                  Background="{DynamicResource PrompletPromptButtonBorderBrush}"
                                                  BorderThickness="0"
                                                  Command="Slider.IncreaseLarge" />
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Width="12"
                                           Height="18">
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource PrompletTextPrimaryBrush}"
                                                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="2" />
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PrompletDialogBackgroundBrush}"
            BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
            BorderThickness="1">
        <DockPanel LastChildFill="True">
            <Grid x:Name="TitleBar"
                  DockPanel.Dock="Top"
                  Height="34"
                  Background="{DynamicResource PrompletHeaderBackgroundBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Promplet Settings"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <Button Grid.Column="1"
                        Content="X"
                        ToolTip="Close"
                        Style="{StaticResource WindowChromeButtonStyle}"
                        Click="Cancel_Click" />
            </Grid>

            <DockPanel LastChildFill="True"
                       Margin="22">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Reset to Defaults"
                        Margin="0,0,12,0"
                        Click="ResetToDefaults_Click" />
                <Button Content="Cancel"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="OK"
                        MinWidth="88"
                        Background="{DynamicResource PrompletAccentBrush}"
                        Foreground="White"
                        Click="Ok_Click" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,18" />

                <Border Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Theme"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemeModeComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  MinWidth="180"
                                  HorizontalAlignment="Left" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Opacity"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="OpacitySlider"
                                Grid.Row="2"
                                Grid.Column="1"
                                Minimum="0.35"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="OpacityValueTextBlock"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="HotKeyStatusTextBlock"
                                   Foreground="{DynamicResource PrompletTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <StackPanel x:Name="HotKeyRowsPanel" />
                    </StackPanel>
                </Border>
            </StackPanel>
            </DockPanel>
        </DockPanel>
    </Border>
</Window>
