<Window x:Class="Promplet.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Promplet Settings"
        Width="640"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ShowInTaskbar="False"
        Background="{DynamicResource PrompletDialogBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{DynamicResource PrompletPromptButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Background" Value="{DynamicResource PrompletDialogInputBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Border Padding="22"
            BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
            BorderThickness="1">
        <DockPanel LastChildFill="True">
            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,18,0,0">
                <Button Content="Reset to Defaults"
                        Margin="0,0,12,0"
                        Click="ResetToDefaults_Click" />
                <Button Content="Cancel"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="OK"
                        MinWidth="88"
                        Background="{DynamicResource PrompletAccentBrush}"
                        Foreground="White"
                        Click="Ok_Click" />
            </StackPanel>

            <StackPanel>
                <TextBlock Text="Settings"
                           FontSize="20"
                           FontWeight="SemiBold"
                           Margin="0,0,0,18" />

                <Border Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16"
                        Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="72" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="12" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0"
                                   Grid.Column="0"
                                   Text="Theme"
                                   VerticalAlignment="Center" />
                        <ComboBox x:Name="ThemeModeComboBox"
                                  Grid.Row="0"
                                  Grid.Column="1"
                                  MinWidth="180"
                                  HorizontalAlignment="Left" />

                        <TextBlock Grid.Row="2"
                                   Grid.Column="0"
                                   Text="Opacity"
                                   VerticalAlignment="Center" />
                        <Slider x:Name="OpacitySlider"
                                Grid.Row="2"
                                Grid.Column="1"
                                Minimum="0.35"
                                Maximum="1"
                                TickFrequency="0.05"
                                IsSnapToTickEnabled="True"
                                VerticalAlignment="Center" />
                        <TextBlock x:Name="OpacityValueTextBlock"
                                   Grid.Row="2"
                                   Grid.Column="2"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <Border Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="16">
                    <StackPanel>
                        <TextBlock Text="Hotkeys"
                                   FontSize="15"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <TextBlock x:Name="HotKeyStatusTextBlock"
                                   Foreground="{DynamicResource PrompletTextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12" />
                        <StackPanel x:Name="HotKeyRowsPanel" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </DockPanel>
    </Border>
</Window>
