<Window x:Class="Promplet.PromptLibraryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Prompt Library"
        Width="920"
        Height="640"
        MinWidth="760"
        MinHeight="520"
        WindowStyle="None"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource PrompletDialogBackgroundBrush}">
    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="12,4" />
            <Setter Property="Background" Value="{DynamicResource PrompletPromptButtonBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28" />
            <Setter Property="Width" Value="36" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletChromeForegroundBrush}" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="Background" Value="{DynamicResource PrompletDialogInputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="ListBox">
            <Setter Property="Background" Value="{DynamicResource PrompletDialogInputBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource PrompletPromptButtonBorderBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="ListBoxItem">
            <Setter Property="Padding" Value="10,7" />
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{DynamicResource PrompletTextPrimaryBrush}" />
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource PrompletDialogBackgroundBrush}"
            BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
            BorderThickness="1">
        <DockPanel LastChildFill="True">
            <Grid x:Name="TitleBar"
                  DockPanel.Dock="Top"
                  Height="34"
                  Background="{DynamicResource PrompletHeaderBackgroundBrush}"
                  MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock Text="Prompt Library"
                           Margin="12,0,0,0"
                           VerticalAlignment="Center"
                           FontSize="12" />
                <Button Grid.Column="1"
                        Content="X"
                        ToolTip="Close"
                        Style="{StaticResource ChromeButtonStyle}"
                        Click="Cancel_Click" />
            </Grid>

            <StackPanel DockPanel.Dock="Bottom"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="20,14,20,20">
                <Button Content="Cancel"
                        MinWidth="88"
                        Margin="0,0,8,0"
                        Click="Cancel_Click" />
                <Button Content="Save"
                        MinWidth="88"
                        Background="{DynamicResource PrompletAccentBrush}"
                        Foreground="White"
                        Click="Save_Click" />
            </StackPanel>

            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="230" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top"
                                    Margin="0,0,0,10">
                            <TextBlock Text="Groups"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       Margin="0,0,0,10" />
                            <TextBox x:Name="GroupNameTextBox"
                                     ToolTip="Group name"
                                     TextChanged="GroupNameTextBox_TextChanged" />
                            <StackPanel Orientation="Horizontal"
                                        Margin="0,10,0,0">
                                <Button Content="Add"
                                        Margin="0,0,6,0"
                                        Click="AddGroup_Click" />
                                <Button Content="Delete"
                                        Click="DeleteGroup_Click" />
                            </StackPanel>
                        </StackPanel>
                        <ListBox x:Name="GroupListBox"
                                 SelectionChanged="GroupListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}"
                                               TextTrimming="CharacterEllipsis" />
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="2"
                        Background="{DynamicResource PrompletDialogPanelBackgroundBrush}"
                        BorderBrush="{DynamicResource PrompletSurfaceBorderBrush}"
                        BorderThickness="1"
                        CornerRadius="8"
                        Padding="14">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="14" />
                            <RowDefinition Height="220" />
                        </Grid.RowDefinitions>

                        <DockPanel Grid.Row="0"
                                   Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Right"
                                        Orientation="Horizontal">
                                <Button Content="Add"
                                        Margin="0,0,6,0"
                                        Click="AddPrompt_Click" />
                                <Button Content="Delete"
                                        Margin="0,0,6,0"
                                        Click="DeletePrompt_Click" />
                                <Button Content="Up"
                                        Margin="0,0,6,0"
                                        Click="MovePromptUp_Click" />
                                <Button Content="Down"
                                        Click="MovePromptDown_Click" />
                            </StackPanel>
                            <TextBlock Text="Prompts"
                                       FontSize="15"
                                       FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                        </DockPanel>

                        <ListBox x:Name="PromptListBox"
                                 Grid.Row="1"
                                 SelectionChanged="PromptListBox_SelectionChanged">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <TextBlock Text="{Binding Label}"
                                                   FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock Grid.Row="1"
                                                   Text="{Binding Text}"
                                                   Foreground="{DynamicResource PrompletTextSecondaryBrush}"
                                                   FontSize="12"
                                                   TextTrimming="CharacterEllipsis" />
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <Grid Grid.Row="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0"
                                       Grid.Column="0"
                                       Text="Name"
                                       VerticalAlignment="Center" />
                            <TextBox x:Name="PromptNameTextBox"
                                     Grid.Row="0"
                                     Grid.Column="1"
                                     TextChanged="PromptNameTextBox_TextChanged" />

                            <TextBlock Grid.Row="2"
                                       Grid.Column="0"
                                       Text="Content"
                                       VerticalAlignment="Top"
                                       Margin="0,6,0,0" />
                            <TextBox x:Name="PromptTextTextBox"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     TextChanged="PromptTextTextBox_TextChanged" />

                            <CheckBox x:Name="PromptEnabledCheckBox"
                                      Grid.Row="3"
                                      Grid.Column="1"
                                      Content="Enabled"
                                      Margin="0,10,0,0"
                                      Checked="PromptEnabledCheckBox_Changed"
                                      Unchecked="PromptEnabledCheckBox_Changed" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </DockPanel>
    </Border>
</Window>
